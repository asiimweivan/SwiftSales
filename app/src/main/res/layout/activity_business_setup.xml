<?xml version="1.0" encoding="utf-8"?>
<!--  activity_business_setup.xml  ✅ Same IDs · ✅ All labels use @string/ for i18n  -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🏪" android:textSize="48sp" android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textSize="26sp" android:textColor="@color/ink_dark" android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/setup_subtitle"
            android:textSize="14sp" android:textColor="@color/ink_soft"
            android:layout_marginBottom="32dp" />

        <!-- Business Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/business_name" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etBusinessName"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="@string/hint_business_name"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:textSize="15sp" android:layout_marginBottom="16dp" />

        <!-- Business Type -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/business_type" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <Spinner android:id="@+id/spinnerBusinessType"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:paddingStart="12dp" android:layout_marginBottom="16dp" />

        <!-- Currency -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/currency" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <Spinner android:id="@+id/spinnerCurrency"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:paddingStart="12dp" android:layout_marginBottom="16dp" />

        <!-- Tax Rate -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/tax_rate" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etTaxRate"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="@string/hint_tax_rate"
            android:inputType="numberDecimal"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:textSize="15sp" android:layout_marginBottom="32dp" />

        <!-- Finish button -->
        <TextView android:id="@+id/btnFinish"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:gravity="center" android:text="@string/finish_setup"
            android:textSize="16sp" android:textColor="#FFFFFF" android:textStyle="bold"
            android:background="@drawable/btn_primary" />

        <!-- Cancel -->
        <TextView android:id="@+id/btnCancel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/cancel"
            android:textSize="15sp" android:textColor="@color/ink_soft"
            android:paddingBottom="16dp" android:layout_marginTop="12dp" />

    </LinearLayout>
</ScrollView>