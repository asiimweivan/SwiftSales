<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">

    <!-- ══ HEADER ════════════════════════════════════════════════════════════ -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@drawable/dashboard_header_bg"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="48dp" android:paddingBottom="20dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <TextView android:id="@+id/btnBackOrders"
                android:layout_width="40dp" android:layout_height="40dp"
                android:gravity="center" android:text="←" android:textSize="22sp"
                android:textColor="#FFFFFF" android:background="@drawable/lang_option_normal"
                android:layout_marginEnd="10dp" />

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/orders_title"
                android:textSize="20sp" android:textColor="#FFFFFF" android:textStyle="bold" />

            <TextView android:id="@+id/btnAddOrder"
                android:layout_width="wrap_content" android:layout_height="38dp"
                android:gravity="center" android:text="@string/add_order_btn"
                android:textSize="13sp" android:textColor="#FFFFFF" android:textStyle="bold"
                android:background="@drawable/btn_accent"
                android:paddingStart="16dp" android:paddingEnd="16dp" />

        </LinearLayout>

        <!-- Stats row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="18dp"
            android:background="#1AFFFFFF" android:padding="12dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tvTotalOrders"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="24sp" android:textColor="#FFFFFF" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/total_orders" android:textSize="10sp" android:textColor="#BAE6FD" android:layout_marginTop="2dp" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="32dp"
                android:layout_gravity="center_vertical" android:background="#33FFFFFF" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tvPendingOrders"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="24sp" android:textColor="#FCD34D" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/pending_orders" android:textSize="10sp" android:textColor="#BAE6FD" android:layout_marginTop="2dp" />
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="32dp"
                android:layout_gravity="center_vertical" android:background="#33FFFFFF" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/tvFulfilledOrders"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textSize="24sp" android:textColor="#86EFAC" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/fulfilled_orders" android:textSize="10sp" android:textColor="#BAE6FD" android:layout_marginTop="2dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ══ FILTER TABS ═══════════════════════════════════════════════════════ -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:scrollbars="none" android:paddingTop="12dp" android:paddingBottom="6dp">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp">

            <TextView android:id="@+id/tabAllOrders"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:gravity="center" android:text="@string/tab_all"
                android:textSize="12sp" android:textColor="#FFFFFF" android:textStyle="bold"
                android:background="@drawable/tab_active_bg"
                android:paddingStart="18dp" android:paddingEnd="18dp" android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/tabPendingOrders"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:gravity="center" android:text="@string/order_status_pending"
                android:textSize="12sp" android:textColor="@color/ink_medium"
                android:background="@drawable/tab_inactive_bg"
                android:paddingStart="18dp" android:paddingEnd="18dp" android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/tabFulfilledOrders"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:gravity="center" android:text="@string/order_status_fulfilled"
                android:textSize="12sp" android:textColor="@color/ink_medium"
                android:background="@drawable/tab_inactive_bg"
                android:paddingStart="18dp" android:paddingEnd="18dp" android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/tabCancelledOrders"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:gravity="center" android:text="@string/order_status_cancelled"
                android:textSize="12sp" android:textColor="@color/ink_medium"
                android:background="@drawable/tab_inactive_bg"
                android:paddingStart="18dp" android:paddingEnd="18dp" android:layout_marginEnd="8dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ══ LIST + EMPTY STATE ════════════════════════════════════════════════ -->
    <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerOrders"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:paddingTop="6dp" android:paddingBottom="16dp"
            android:clipToPadding="false" android:scrollbars="none" />

        <LinearLayout android:id="@+id/emptyOrders"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:gravity="center" android:visibility="gone">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📋" android:textSize="64sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/no_orders_yet" android:textSize="18sp"
                android:textColor="@color/ink_dark" android:textStyle="bold" android:layout_marginTop="16dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/add_first_order" android:textSize="14sp"
                android:textColor="@color/ink_soft" android:layout_marginTop="8dp" android:gravity="center"
                android:paddingHorizontal="32dp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>