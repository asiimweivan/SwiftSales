<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp" app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <!-- Row 1: channel + status badge + delete -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView android:id="@+id/tvOrderChannel"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="📞  Phone"
                android:textSize="13sp" android:textColor="@color/ink_medium" />

            <TextView android:id="@+id/tvOrderStatus"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Pending" android:textSize="11sp" android:textColor="@color/warning"
                android:textStyle="bold" android:background="@drawable/badge_warning"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"
                android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/btnDeleteOrder"
                android:layout_width="30dp" android:layout_height="30dp"
                android:gravity="center" android:text="🗑" android:textSize="14sp"
                android:background="@drawable/btn_danger_outline" />

        </LinearLayout>

        <!-- Row 2: customer name + total -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView android:id="@+id/tvOrderCustomerName"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Customer"
                android:textSize="15sp" android:textColor="@color/ink_dark" android:textStyle="bold" />

            <TextView android:id="@+id/tvOrderTotal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RWF 0" android:textSize="15sp"
                android:textColor="@color/primary" android:textStyle="bold" />

        </LinearLayout>

        <!-- Row 3: contact + item count -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">

            <TextView android:id="@+id/tvOrderContact"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="—"
                android:textSize="12sp" android:textColor="@color/ink_soft" />

            <TextView android:id="@+id/tvOrderItemCount"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 items" android:textSize="12sp" android:textColor="@color/ink_soft" />

        </LinearLayout>

        <!-- Date -->
        <TextView android:id="@+id/tvOrderDate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="—" android:textSize="11sp" android:textColor="@color/ink_soft"
            android:layout_marginBottom="10dp" />

        <!-- Action buttons — only shown for Pending -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/btnCancelOrder"
                android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
                android:gravity="center" android:text="@string/cancel_order_btn"
                android:textSize="13sp" android:textColor="@color/danger" android:textStyle="bold"
                android:background="@drawable/btn_danger_outline" android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/btnFulfilOrder"
                android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="2"
                android:gravity="center" android:text="@string/fulfil_order_btn"
                android:textSize="13sp" android:textColor="#FFFFFF" android:textStyle="bold"
                android:background="@drawable/btn_primary" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>