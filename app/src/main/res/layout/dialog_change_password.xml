<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_change_password.xml  ✅ Same IDs · ✅ Labels use @string/ for i18n
    IDs: etCurrentPassword, etNewPassword, etConfirmNewPassword,
         btnCancelPassword, btnSavePassword
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:padding="24dp"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@drawable/bar_inactive"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/change_password_title"
        android:textSize="18sp"
        android:textColor="@color/ink_dark"
        android:textStyle="bold"
        android:layout_marginBottom="20dp" />

    <!-- Current Password -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/label_current_password" android:textSize="13sp"
        android:textColor="@color/ink_medium" android:textStyle="bold"
        android:layout_marginBottom="6dp" />
    <EditText
        android:id="@+id/etCurrentPassword"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:hint="@string/hint_current_password"
        android:inputType="textPassword"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:textSize="15sp" android:layout_marginBottom="14dp" />

    <!-- New Password -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/label_new_password" android:textSize="13sp"
        android:textColor="@color/ink_medium" android:textStyle="bold"
        android:layout_marginBottom="6dp" />
    <EditText
        android:id="@+id/etNewPassword"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:hint="@string/hint_password_min"
        android:inputType="textPassword"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:textSize="15sp" android:layout_marginBottom="14dp" />

    <!-- Confirm New Password -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/label_confirm_new_password" android:textSize="13sp"
        android:textColor="@color/ink_medium" android:textStyle="bold"
        android:layout_marginBottom="6dp" />
    <EditText
        android:id="@+id/etConfirmNewPassword"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:hint="@string/hint_confirm_password"
        android:inputType="textPassword"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:textSize="15sp" android:layout_marginBottom="20dp" />

    <!-- Buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/btnCancelPassword"
            android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
            android:gravity="center" android:text="@string/cancel"
            android:textSize="15sp" android:textColor="@color/ink_medium" android:textStyle="bold"
            android:background="@drawable/btn_outline" android:layout_marginEnd="8dp" />
        <TextView android:id="@+id/btnSavePassword"
            android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
            android:gravity="center" android:text="@string/update_password_btn"
            android:textSize="15sp" android:textColor="#FFFFFF" android:textStyle="bold"
            android:background="@drawable/btn_primary" />
    </LinearLayout>

</LinearLayout>