<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_edit_setting.xml  ✅ Same IDs · ✅ Labels use @string/ for i18n
    IDs: tvEditSettingTitle, etSettingValue, btnCancelSetting, btnSaveSetting
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:padding="24dp"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="@drawable/bar_inactive"
        android:layout_marginBottom="20dp" />

    <!-- Title — set dynamically by SettingsActivity -->
    <TextView
        android:id="@+id/tvEditSettingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/edit"
        android:textSize="18sp"
        android:textColor="@color/ink_dark"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Value field — hint set dynamically -->
    <EditText
        android:id="@+id/etSettingValue"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textSize="15sp"
        android:layout_marginBottom="20dp" />

    <!-- Buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/btnCancelSetting"
            android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
            android:gravity="center" android:text="@string/cancel"
            android:textSize="15sp" android:textColor="@color/ink_medium" android:textStyle="bold"
            android:background="@drawable/btn_outline" android:layout_marginEnd="8dp" />
        <TextView android:id="@+id/btnSaveSetting"
            android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
            android:gravity="center" android:text="@string/save"
            android:textSize="15sp" android:textColor="#FFFFFF" android:textStyle="bold"
            android:background="@drawable/btn_primary" />
    </LinearLayout>

</LinearLayout>