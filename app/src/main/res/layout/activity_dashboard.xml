<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_dashboard.xml
    ✅  All original IDs kept
    ✅  tvBell and tvAvatar are tappable → Notifications / Profile
    ✅  btnRegisterOrder added below quick actions → Orders
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ HEADER ══════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/dashboard_header_bg"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Greeting + name -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/good_morning"
                            android:textSize="13sp"
                            android:textColor="#BAE6FD" />

                        <TextView
                            android:id="@+id/tvUserName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="John Doe"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvBusinessName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Shop Ltd"
                            android:textSize="12sp"
                            android:textColor="#7ABFEA" />

                    </LinearLayout>

                    <!-- Bell → NotificationsActivity  ✅ clickable -->
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="10dp">

                        <TextView
                            android:id="@+id/tvBell"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="🔔"
                            android:textSize="20sp"
                            android:background="@drawable/lang_option_normal"
                            android:clickable="true"
                            android:focusable="true" />

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="2dp"
                            android:background="@drawable/dot_active" />

                    </FrameLayout>

                    <!-- Avatar → ProfileActivity  ✅ clickable -->
                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:text="JD"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:background="@drawable/avatar_bg"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- Today's revenue label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/todays_revenue"
                    android:textSize="11sp"
                    android:textColor="#7ABFEA"
                    android:letterSpacing="0.12"
                    android:layout_marginTop="24dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RWF 0"
                        android:textSize="34sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvTrend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="↑ 0%"
                        android:textSize="12sp"
                        android:textColor="#10B981"
                        android:textStyle="bold"
                        android:background="@drawable/badge_success"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══ STAT CARDS ══════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp">

                <!-- Row 1: Orders + Products -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">

                    <LinearLayout android:id="@+id/cardOrders"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/card_bg" android:padding="16dp"
                        android:layout_marginEnd="6dp" android:elevation="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🧾" android:textSize="22sp" />
                        <TextView android:id="@+id/tvOrdersCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="24sp"
                            android:textColor="@color/ink_dark" android:textStyle="bold"
                            android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/orders_today" android:textSize="12sp"
                            android:textColor="@color/ink_soft" android:layout_marginTop="2dp" />
                        <TextView android:id="@+id/tvOrdersTrend"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/vs_yesterday" android:textSize="11sp"
                            android:textColor="@color/success" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/cardProducts"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/card_bg" android:padding="16dp"
                        android:layout_marginStart="6dp" android:elevation="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📦" android:textSize="22sp" />
                        <TextView android:id="@+id/tvProductsCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="24sp"
                            android:textColor="@color/ink_dark" android:textStyle="bold"
                            android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/products" android:textSize="12sp"
                            android:textColor="@color/ink_soft" android:layout_marginTop="2dp" />
                        <TextView android:id="@+id/tvLowStock"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 low stock" android:textSize="11sp"
                            android:textColor="@color/warning" android:layout_marginTop="4dp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2: Staff + Profit -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="12dp">

                    <LinearLayout android:id="@+id/cardStaff"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/card_bg" android:padding="16dp"
                        android:layout_marginEnd="6dp" android:elevation="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👥" android:textSize="22sp" />
                        <TextView android:id="@+id/tvStaffCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="24sp"
                            android:textColor="@color/ink_dark" android:textStyle="bold"
                            android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/active_staff" android:textSize="12sp"
                            android:textColor="@color/ink_soft" android:layout_marginTop="2dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/on_shift" android:textSize="11sp"
                            android:textColor="@color/success" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:id="@+id/cardProfit"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:background="@drawable/card_bg" android:padding="16dp"
                        android:layout_marginStart="6dp" android:elevation="2dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💰" android:textSize="22sp" />
                        <TextView android:id="@+id/tvProfitAmount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="24sp"
                            android:textColor="@color/ink_dark" android:textStyle="bold"
                            android:layout_marginTop="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/net_profit" android:textSize="12sp"
                            android:textColor="@color/ink_soft" android:layout_marginTop="2dp" />
                        <TextView android:id="@+id/tvProfitMargin"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0%" android:textSize="11sp"
                            android:textColor="@color/primary" android:layout_marginTop="4dp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ══ QUICK ACTIONS ═══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp">

                <!-- Row 1: New Sale | Add Product | Reports -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView android:id="@+id/btnNewSale"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/new_sale" android:textSize="13sp"
                        android:textColor="#FFFFFF" android:textStyle="bold"
                        android:background="@drawable/btn_accent"
                        android:layout_marginEnd="8dp" />

                    <TextView android:id="@+id/btnAddProduct"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/add_product" android:textSize="13sp"
                        android:textColor="#FFFFFF" android:textStyle="bold"
                        android:background="@drawable/btn_primary"
                        android:layout_marginEnd="8dp" />

                    <TextView android:id="@+id/btnViewReports"
                        android:layout_width="0dp" android:layout_height="48dp"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/view_reports" android:textSize="13sp"
                        android:textColor="@color/primary" android:textStyle="bold"
                        android:background="@drawable/btn_outline" />

                </LinearLayout>

                <!-- Row 2: Register Order (full width) ✅ NEW -->
                <TextView
                    android:id="@+id/btnRegisterOrder"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="@string/register_order_btn"
                    android:textSize="14sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:background="@drawable/btn_outline" />

            </LinearLayout>

            <!-- ══ WEEKLY CHART ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:padding="16dp"
                android:elevation="2dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/weekly_sales"
                        android:textSize="15sp" android:textColor="@color/ink_dark" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/this_week" android:textSize="12sp"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <LinearLayout android:id="@+id/chartContainer"
                    android:layout_width="match_parent" android:layout_height="120dp"
                    android:orientation="horizontal" android:gravity="bottom" android:weightSum="7">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <View android:id="@+id/bar0" android:layout_width="24dp" android:layout_height="40dp" android:background="@drawable/bar_inactive" android:layout_gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mon" android:textSize="9sp" android:textColor="@color/ink_soft" android:layout_marginTop="4dp" android:layout_gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <View android:id="@+id/bar1" android:layout_width="24dp" android:layout_height="60dp" android:background="@drawable/bar_inactive" android:layout_gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tue" android:textSize="9sp" android:textColor="@color/ink_soft" android:layout_marginTop="4dp" android:layout_gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <View android:id="@+id/bar2" android:layout_width="24dp" android:layout_height="80dp" android:background="@drawable/bar_inactive" android:layout_gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Wed" android:textSize="9sp" android:textColor="@color/ink_soft" android:layout_marginTop="4dp" android:layout_gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <View android:id="@+id/bar3" android:layout_width="24dp" android:layout_height="50dp" android:background="@drawable/bar_inactive" android:layout_gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thu" android:textSize="9sp" android:textColor="@color/ink_soft" android:layout_marginTop="4dp" android:layout_gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <View android:id="@+id/bar4" android:layout_width="24dp" android:layout_height="70dp" android:background="@drawable/bar_inactive" android:layout_gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fri" android:textSize="9sp" android:textColor="@color/ink_soft" android:layout_marginTop="4dp" android:layout_gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <View android:id="@+id/bar5" android:layout_width="24dp" android:layout_height="90dp" android:background="@drawable/bar_inactive" android:layout_gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sat" android:textSize="9sp" android:textColor="@color/ink_soft" android:layout_marginTop="4dp" android:layout_gravity="center" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <View android:id="@+id/bar6" android:layout_width="24dp" android:layout_height="100dp" android:background="@drawable/bar_active" android:layout_gravity="center" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Today" android:textSize="9sp" android:textColor="@color/accent" android:textStyle="bold" android:layout_marginTop="4dp" android:layout_gravity="center" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ══ RECENT SALES ════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:padding="16dp"
                android:elevation="2dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/recent_sales"
                        android:textSize="15sp" android:textColor="@color/ink_dark" android:textStyle="bold" />
                    <TextView android:id="@+id/tvViewAll"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/view_all" android:textSize="12sp"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <!-- Empty state -->
                <LinearLayout android:id="@+id/emptyState"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🛒" android:textSize="40sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/no_sales_today" android:textSize="14sp"
                        android:textColor="@color/ink_soft" android:layout_marginTop="8dp" />
                    <TextView android:id="@+id/btnStartSelling"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/start_first_sale" android:textSize="13sp"
                        android:textColor="@color/primary" android:textStyle="bold"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Sales container — RecyclerView added programmatically -->
                <LinearLayout android:id="@+id/salesContainer"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ══ BOTTOM NAVIGATION ══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@drawable/bottom_nav_bg"
        android:elevation="16dp">

        <LinearLayout android:id="@+id/tabDashboard"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⊞" android:textSize="20sp" android:textColor="@color/primary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_home" android:textSize="10sp"
                android:textColor="@color/primary" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:id="@+id/tabPOS"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🛒" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_pos" android:textSize="10sp"
                android:textColor="@color/ink_soft" />
        </LinearLayout>

        <LinearLayout android:id="@+id/tabInventory"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📦" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_inventory" android:textSize="10sp"
                android:textColor="@color/ink_soft" />
        </LinearLayout>

        <LinearLayout android:id="@+id/tabReports"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_reports" android:textSize="10sp"
                android:textColor="@color/ink_soft" />
        </LinearLayout>

        <LinearLayout android:id="@+id/tabStaff"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👥" android:textSize="20sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_staff" android:textSize="10sp"
                android:textColor="@color/ink_soft" />
        </LinearLayout>

        <LinearLayout android:id="@+id/tabSettings"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙️" android:textSize="20sp" />
            <TextView android:id="@+id/btnSettingsIcon"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/nav_settings" android:textSize="10sp"
                android:textColor="@color/ink_soft" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>