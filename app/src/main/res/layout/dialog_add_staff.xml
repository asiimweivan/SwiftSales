<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_add_staff.xml — Add / Edit Staff Bottom Sheet
    ✅ Same IDs
    ✅ All labels use @string/
    ✅ No external icon drawables (ic_phone / ic_email removed — they don't exist)
    ✅ Uses plain EditText inside TextInputLayout — matches AddEditStaffSheet.java
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="36dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bar_inactive"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvStaffDialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_staff_member"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/ink_dark"
            android:layout_marginBottom="20dp" />

        <!-- Full Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/staff_hint_name"
            android:textSize="13sp"
            android:textColor="@color/ink_medium"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etStaffName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:inputType="textCapWords"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:imeOptions="actionNext"
            android:layout_marginBottom="14dp" />

        <!-- Phone -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/staff_hint_phone"
            android:textSize="13sp"
            android:textColor="@color/ink_medium"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etStaffPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:inputType="phone"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:imeOptions="actionNext"
            android:layout_marginBottom="14dp" />

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/staff_hint_email"
            android:textSize="13sp"
            android:textColor="@color/ink_medium"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etStaffEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:inputType="textEmailAddress"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:imeOptions="actionNext"
            android:layout_marginBottom="14dp" />

        <!-- Role -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/staff_hint_role"
            android:textSize="13sp"
            android:textColor="@color/ink_medium"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerRole"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:paddingStart="12dp"
            android:layout_marginBottom="14dp" />

        <!-- PIN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/staff_hint_pin"
            android:textSize="13sp"
            android:textColor="@color/ink_medium"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/etStaffPin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:inputType="numberPassword"
            android:maxLength="4"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="20sp"
            android:letterSpacing="0.3"
            android:imeOptions="actionDone"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/staff_pin_helper"
            android:textSize="11sp"
            android:textColor="@color/ink_soft"
            android:layout_marginBottom="24dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnCancelStaff"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/cancel"
                android:textSize="15sp"
                android:textColor="@color/ink_medium"
                android:textStyle="bold"
                android:background="@drawable/btn_outline"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btnSaveStaff"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/save"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/btn_primary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>