<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_reports.xml  —  SwiftSales Reports Screen
    ────────────────────────────────────────────────────
    ✅  Keeps ALL original view IDs
    ✅  All hard-coded labels replaced with @string/ for i18n
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ══ HEADER ════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/dashboard_header_bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBackReports"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="←"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/lang_option_normal"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reports_title"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvReportDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#BAE6FD" />

        </LinearLayout>

        <!-- Period tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="@drawable/lang_option_normal"
            android:layout_marginTop="16dp"
            android:padding="4dp">

            <TextView
                android:id="@+id/tabToday"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/period_today"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/tab_active_bg" />

            <TextView
                android:id="@+id/tabWeek"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/period_week"
                android:textSize="13sp"
                android:textColor="#BAE6FD"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/tabMonth"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/period_month"
                android:textSize="13sp"
                android:textColor="#BAE6FD"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/tabAll"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/period_all"
                android:textSize="13sp"
                android:textColor="#BAE6FD"
                android:background="@android:color/transparent" />

        </LinearLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══ KPI ROW 1 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Revenue -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="2dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💰" android:textSize="24sp" />
                    <TextView
                        android:id="@+id/tvKpiRevenue"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="20sp"
                        android:textColor="@color/primary" android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/kpi_revenue" android:textSize="12sp"
                        android:textColor="@color/ink_soft" android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Profit -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="16dp"
                    android:elevation="2dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📈" android:textSize="24sp" />
                    <TextView
                        android:id="@+id/tvKpiProfit"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="20sp"
                        android:textColor="@color/success" android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/kpi_profit" android:textSize="12sp"
                        android:textColor="@color/ink_soft" android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══ KPI ROW 2 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Orders -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="2dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧾" android:textSize="24sp" />
                    <TextView
                        android:id="@+id/tvKpiOrders"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="20sp"
                        android:textColor="@color/accent" android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/kpi_orders" android:textSize="12sp"
                        android:textColor="@color/ink_soft" android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- Avg Order -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/card_bg"
                    android:padding="16dp"
                    android:elevation="2dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎯" android:textSize="24sp" />
                    <TextView
                        android:id="@+id/tvKpiAvg"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="20sp"
                        android:textColor="@color/ink_dark" android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/kpi_avg_order" android:textSize="12sp"
                        android:textColor="@color/ink_soft" android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ══ PAYMENT BREAKDOWN ══════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_methods"
                    android:textSize="15sp"
                    android:textColor="@color/ink_dark"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Cash -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="72dp" android:layout_height="wrap_content"
                        android:text="💵  Cash" android:textSize="13sp" android:textColor="@color/ink_medium" />
                    <View android:id="@+id/barCash" android:layout_width="0dp" android:layout_height="10dp"
                        android:layout_weight="1" android:background="@drawable/bar_active"
                        android:layout_marginEnd="8dp" />
                    <TextView android:id="@+id/tvCashPct" android:layout_width="36dp"
                        android:layout_height="wrap_content" android:text="0%"
                        android:textSize="12sp" android:textColor="@color/ink_soft" android:gravity="end" />
                </LinearLayout>

                <!-- Mobile -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="72dp" android:layout_height="wrap_content"
                        android:text="📱  Mobile" android:textSize="13sp" android:textColor="@color/ink_medium" />
                    <View android:id="@+id/barMobile" android:layout_width="0dp" android:layout_height="10dp"
                        android:layout_weight="1" android:background="@drawable/bar_inactive"
                        android:layout_marginEnd="8dp" />
                    <TextView android:id="@+id/tvMobilePct" android:layout_width="36dp"
                        android:layout_height="wrap_content" android:text="0%"
                        android:textSize="12sp" android:textColor="@color/ink_soft" android:gravity="end" />
                </LinearLayout>

                <!-- Card -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="72dp" android:layout_height="wrap_content"
                        android:text="💳  Card" android:textSize="13sp" android:textColor="@color/ink_medium" />
                    <View android:id="@+id/barCard" android:layout_width="0dp" android:layout_height="10dp"
                        android:layout_weight="1" android:background="@drawable/bar_inactive"
                        android:layout_marginEnd="8dp" />
                    <TextView android:id="@+id/tvCardPct" android:layout_width="36dp"
                        android:layout_height="wrap_content" android:text="0%"
                        android:textSize="12sp" android:textColor="@color/ink_soft" android:gravity="end" />
                </LinearLayout>

            </LinearLayout>

            <!-- ══ SALES HISTORY ══════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sales_history"
                    android:textSize="15sp"
                    android:textColor="@color/ink_dark"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSaleCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="12sp"
                    android:textColor="@color/ink_soft" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/emptySales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🧾" android:textSize="48sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_sales_period"
                    android:textSize="15sp"
                    android:textColor="@color/ink_soft"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>