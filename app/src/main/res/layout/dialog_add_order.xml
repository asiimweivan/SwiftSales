<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:background="@color/white" android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="12dp" android:paddingBottom="36dp">

        <!-- Drag handle -->
        <View android:layout_width="40dp" android:layout_height="4dp"
            android:layout_gravity="center_horizontal" android:background="@drawable/bar_inactive"
            android:layout_marginBottom="16dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/add_order_title" android:textSize="20sp"
            android:textColor="@color/ink_dark" android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- Customer Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/order_customer_name" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etOrderCustomerName"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="@string/order_customer_name_hint"
            android:inputType="textCapWords" android:background="@drawable/input_bg"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:textSize="15sp" android:layout_marginBottom="14dp" />

        <!-- Customer Contact -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/order_customer_contact" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etOrderCustomerContact"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="@string/order_customer_contact_hint"
            android:inputType="phone" android:background="@drawable/input_bg"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:textSize="15sp" android:layout_marginBottom="14dp" />

        <!-- Channel -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/order_channel" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <Spinner android:id="@+id/spinnerOrderChannel"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/input_bg" android:paddingStart="12dp"
            android:layout_marginBottom="14dp" />

        <!-- Items section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/order_items"
                android:textSize="13sp" android:textColor="@color/ink_medium" android:textStyle="bold" />

            <TextView android:id="@+id/btnAddOrderItem"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:gravity="center" android:text="@string/add_item_btn"
                android:textSize="12sp" android:textColor="@color/primary" android:textStyle="bold"
                android:background="@drawable/btn_outline_primary"
                android:paddingStart="14dp" android:paddingEnd="14dp" />

        </LinearLayout>

        <!-- Items container — rows added programmatically -->
        <LinearLayout android:id="@+id/orderItemsContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginBottom="14dp" />

        <!-- Notes -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/order_notes" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etOrderNotes"
            android:layout_width="match_parent" android:layout_height="80dp"
            android:hint="@string/order_notes_hint"
            android:inputType="textMultiLine" android:gravity="top"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="12dp"
            android:textSize="14sp" android:layout_marginBottom="20dp" />

        <!-- Buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/btnCancelOrder"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:text="@string/cancel"
                android:textSize="15sp" android:textColor="@color/ink_medium" android:textStyle="bold"
                android:background="@drawable/btn_outline" android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/btnSaveOrder"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:text="@string/save_order_btn"
                android:textSize="15sp" android:textColor="#FFFFFF" android:textStyle="bold"
                android:background="@drawable/btn_primary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>