<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_add_product.xml
    ✅ Same IDs
    ✅ All labels use @string/
    ✅ NEW: btnScanBarcode next to etBarcode — triggers ZXing scanner
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Handle -->
        <View android:layout_width="40dp" android:layout_height="4dp"
            android:layout_gravity="center" android:background="@drawable/bar_inactive"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvDialogTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/add_product_title" android:textSize="20sp"
            android:textColor="@color/ink_dark" android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Emoji picker -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/product_icon_label" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">

            <TextView android:id="@+id/tvSelectedEmoji"
                android:layout_width="56dp" android:layout_height="56dp"
                android:gravity="center" android:text="📦" android:textSize="28sp"
                android:background="@drawable/onboarding_circle_bg"
                android:layout_marginEnd="12dp" />

            <HorizontalScrollView android:layout_width="0dp" android:layout_height="56dp"
                android:layout_weight="1" android:scrollbars="none">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/emoji1" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="📦" android:textSize="24sp" android:background="@drawable/onboarding_circle_bg" android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/emoji2" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="🍎" android:textSize="24sp" android:background="@drawable/onboarding_circle_bg" android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/emoji3" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="🥤" android:textSize="24sp" android:background="@drawable/onboarding_circle_bg" android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/emoji4" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="🧴" android:textSize="24sp" android:background="@drawable/onboarding_circle_bg" android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/emoji5" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="🍞" android:textSize="24sp" android:background="@drawable/onboarding_circle_bg" android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/emoji6" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="🧃" android:textSize="24sp" android:background="@drawable/onboarding_circle_bg" android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/emoji7" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="📱" android:textSize="24sp" android:background="@drawable/onboarding_circle_bg" android:layout_marginEnd="6dp" />
                    <TextView android:id="@+id/emoji8" android:layout_width="44dp" android:layout_height="44dp" android:gravity="center" android:text="🧹" android:textSize="24sp" android:background="@drawable/onboarding_circle_bg" />
                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>

        <!-- Product Name -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/product_name_label" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <EditText android:id="@+id/etProductName"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="@string/product_name_hint"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp" android:paddingEnd="16dp"
            android:textSize="15sp" android:layout_marginBottom="16dp" />

        <!-- Category -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/category_label" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />
        <Spinner android:id="@+id/spinnerCategory"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:paddingStart="12dp" android:layout_marginBottom="16dp" />

        <!-- Selling Price & Cost Price -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/selling_price_label" android:textSize="13sp"
                    android:textColor="@color/ink_medium" android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <EditText android:id="@+id/etSellingPrice"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="0" android:inputType="numberDecimal"
                    android:background="@drawable/input_bg"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/cost_price_label" android:textSize="13sp"
                    android:textColor="@color/ink_medium" android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <EditText android:id="@+id/etCostPrice"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="0" android:inputType="numberDecimal"
                    android:background="@drawable/input_bg"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Stock & Low Stock Alert -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/stock_qty_label" android:textSize="13sp"
                    android:textColor="@color/ink_medium" android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <EditText android:id="@+id/etStock"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="0" android:inputType="number"
                    android:background="@drawable/input_bg"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/low_stock_alert_label" android:textSize="13sp"
                    android:textColor="@color/ink_medium" android:textStyle="bold"
                    android:layout_marginBottom="6dp" />
                <EditText android:id="@+id/etLowStockAlert"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="5" android:inputType="number"
                    android:background="@drawable/input_bg"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- ══ BARCODE — field + scan button side by side ══════════════════════ -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/barcode_label" android:textSize="13sp"
            android:textColor="@color/ink_medium" android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/etBarcode"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="@string/barcode_hint"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="15sp"
                android:inputType="text"
                android:layout_marginEnd="8dp" />

            <!-- Scan button — triggers ZXing camera scanner -->
            <TextView
                android:id="@+id/btnScanBarcode"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="📷"
                android:textSize="22sp"
                android:background="@drawable/btn_primary"
                android:contentDescription="@string/scan_barcode_btn" />

        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/btnCancelProduct"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:text="@string/cancel"
                android:textSize="15sp" android:textColor="@color/ink_medium" android:textStyle="bold"
                android:background="@drawable/btn_outline" android:layout_marginEnd="8dp" />

            <TextView android:id="@+id/btnSaveProduct"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:gravity="center" android:text="@string/save_product_btn"
                android:textSize="15sp" android:textColor="#FFFFFF" android:textStyle="bold"
                android:background="@drawable/btn_primary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>