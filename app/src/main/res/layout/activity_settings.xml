<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_settings.xml  —  SwiftSales Settings Screen
    ──────────────────────────────────────────────────────
    ✅  Keeps ALL original view IDs
    ✅  All hard-coded labels replaced with @string/ for i18n
    ✅  paddingLeft/Right → paddingStart/End (RTL-safe)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ══ HEADER ════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/dashboard_header_bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBackSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="←"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/lang_option_normal"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_title"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAppVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.0"
                android:textSize="12sp"
                android:textColor="#BAE6FD" />

        </LinearLayout>

        <!-- Business info preview card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:background="@drawable/lang_option_normal"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSettingsAvatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="SB"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/avatar_bg"
                android:layout_marginEnd="14dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSettingsBusinessName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Business"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSettingsUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Owner"
                    android:textSize="13sp"
                    android:textColor="#BAE6FD"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvSettingsCurrency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RWF"
                android:textSize="14sp"
                android:textColor="#BAE6FD"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══ BUSINESS SETTINGS ══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_business"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <!-- Business Name -->
                <LinearLayout android:id="@+id/rowBusinessName"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏪" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_business_name"
                        android:textSize="14sp" android:textColor="@color/ink_dark" />
                    <TextView android:id="@+id/tvBizName" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textColor="@color/ink_soft"
                        android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Business Type -->
                <LinearLayout android:id="@+id/rowBusinessType"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏷️" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_business_type"
                        android:textSize="14sp" android:textColor="@color/ink_dark" />
                    <TextView android:id="@+id/tvBizType" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textColor="@color/ink_soft"
                        android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Currency -->
                <LinearLayout android:id="@+id/rowCurrency"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💱" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_currency"
                        android:textSize="14sp" android:textColor="@color/ink_dark" />
                    <TextView android:id="@+id/tvCurrency" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="RWF"
                        android:textSize="13sp" android:textColor="@color/ink_soft"
                        android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Tax Rate -->
                <LinearLayout android:id="@+id/rowTax"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧾" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_tax_rate"
                        android:textSize="14sp" android:textColor="@color/ink_dark" />
                    <TextView android:id="@+id/tvTaxRate" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0%"
                        android:textSize="13sp" android:textColor="@color/ink_soft"
                        android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
                </LinearLayout>

            </LinearLayout>

            <!-- ══ ACCOUNT SETTINGS ═══════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_account"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <!-- Full Name -->
                <LinearLayout android:id="@+id/rowFullName"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👤" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_full_name"
                        android:textSize="14sp" android:textColor="@color/ink_dark" />
                    <TextView android:id="@+id/tvFullName" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textColor="@color/ink_soft"
                        android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Phone -->
                <LinearLayout android:id="@+id/rowPhone"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📞" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_phone"
                        android:textSize="14sp" android:textColor="@color/ink_dark" />
                    <TextView android:id="@+id/tvPhone" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="13sp" android:textColor="@color/ink_soft"
                        android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Change Password -->
                <LinearLayout android:id="@+id/rowPassword"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_change_password"
                        android:textSize="14sp" android:textColor="@color/ink_dark" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
                </LinearLayout>

            </LinearLayout>

            <!-- ══ APP SETTINGS ═══════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_app"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <!-- Language -->
                <LinearLayout android:id="@+id/rowLanguage"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🌐" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_language"
                        android:textSize="14sp" android:textColor="@color/ink_dark" />
                    <TextView android:id="@+id/tvLanguage" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="English"
                        android:textSize="13sp" android:textColor="@color/ink_soft"
                        android:layout_marginEnd="8dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Receipt Footer -->
                <LinearLayout android:id="@+id/rowReceipt"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🖨️" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_receipt_footer"
                        android:textSize="14sp" android:textColor="@color/ink_dark" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
                </LinearLayout>

            </LinearLayout>

            <!-- ══ DANGER ZONE ════════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_danger"
                android:textSize="11sp"
                android:textColor="@color/danger"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <!-- Sign Out -->
                <LinearLayout android:id="@+id/rowSignOut"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔑" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/sign_out"
                        android:textSize="14sp" android:textColor="@color/danger"
                        android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/danger" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Clear All Data -->
                <LinearLayout android:id="@+id/rowClearData"
                    android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🗑️" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/clear_all_data"
                        android:textSize="14sp" android:textColor="@color/danger"
                        android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="20sp" android:textColor="@color/danger" />
                </LinearLayout>

            </LinearLayout>

            <!-- App info footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ SwiftSales"
                    android:textSize="16sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_footer"
                    android:textSize="12sp"
                    android:textColor="@color/ink_soft"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>