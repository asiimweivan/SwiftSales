<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="@drawable/dashboard_header_bg"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="48dp" android:paddingBottom="28dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView android:id="@+id/btnBackProfile"
                android:layout_width="40dp" android:layout_height="40dp"
                android:gravity="center" android:text="←" android:textSize="22sp"
                android:textColor="#FFFFFF" android:background="@drawable/lang_option_normal"
                android:layout_marginEnd="10dp" />

            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="@string/profile_title"
                android:textSize="20sp" android:textColor="#FFFFFF" android:textStyle="bold" />

        </LinearLayout>

        <!-- Avatar + name card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/lang_option_normal" android:padding="16dp">

            <TextView android:id="@+id/tvProfileAvatar"
                android:layout_width="60dp" android:layout_height="60dp"
                android:gravity="center" android:text="JD"
                android:textSize="22sp" android:textColor="#FFFFFF" android:textStyle="bold"
                android:background="@drawable/avatar_bg" android:layout_marginEnd="16dp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">

                <TextView android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="18sp"
                    android:textColor="#FFFFFF" android:textStyle="bold" />

                <TextView android:id="@+id/tvProfileBusiness"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="—" android:textSize="13sp" android:textColor="#BAE6FD"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Info card -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/card_bg"
                android:layout_marginBottom="16dp" android:elevation="2dp">

                <!-- Phone -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📞" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_phone"
                        android:textSize="14sp" android:textColor="@color/ink_soft" />
                    <TextView android:id="@+id/tvProfilePhone"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp"
                        android:textColor="@color/ink_dark" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Email -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✉️" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/email_optional"
                        android:textSize="14sp" android:textColor="@color/ink_soft" />
                    <TextView android:id="@+id/tvProfileEmail"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp"
                        android:textColor="@color/ink_dark" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Currency -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💱" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_currency"
                        android:textSize="14sp" android:textColor="@color/ink_soft" />
                    <TextView android:id="@+id/tvProfileCurrency"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="RWF" android:textSize="14sp"
                        android:textColor="@color/ink_dark" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginStart="48dp" />

                <!-- Business Type -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingStart="16dp" android:paddingEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏷️" android:textSize="18sp" android:layout_marginEnd="14dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="@string/setting_business_type"
                        android:textSize="14sp" android:textColor="@color/ink_soft" />
                    <TextView android:id="@+id/tvProfileRole"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp"
                        android:textColor="@color/ink_dark" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- Shortcut buttons -->
            <LinearLayout android:id="@+id/btnGoToSettings"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/card_bg"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:layout_marginBottom="12dp" android:elevation="2dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⚙️" android:textSize="18sp" android:layout_marginEnd="14dp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/go_to_settings"
                    android:textSize="15sp" android:textColor="@color/ink_dark" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
            </LinearLayout>

            <LinearLayout android:id="@+id/btnGoToPassword"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/card_bg"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:elevation="2dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔒" android:textSize="18sp" android:layout_marginEnd="14dp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/setting_change_password"
                    android:textSize="15sp" android:textColor="@color/ink_dark" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="20sp" android:textColor="@color/ink_soft" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>