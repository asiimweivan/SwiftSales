<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/card_bg"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:elevation="1dp">

    <!-- Emoji -->
    <TextView
        android:id="@+id/tvCartEmoji"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="📦"
        android:textSize="22sp"
        android:background="@drawable/onboarding_inner_circle"
        android:layout_marginEnd="12dp" />

    <!-- Name + price -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCartName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product"
            android:textSize="14sp"
            android:textColor="@color/ink_dark"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCartUnitPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RWF 0 each"
            android:textSize="12sp"
            android:textColor="@color/ink_soft"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Qty controls -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/tab_inactive_bg"
        android:paddingLeft="4dp"
        android:paddingRight="4dp">

        <TextView
            android:id="@+id/btnDecrease"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="−"
            android:textSize="18sp"
            android:textColor="@color/danger"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvQty"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="1"
            android:textSize="15sp"
            android:textColor="@color/ink_dark"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnIncrease"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="＋"
            android:textSize="18sp"
            android:textColor="@color/primary"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Line total -->
    <TextView
        android:id="@+id/tvCartLineTotal"
        android:layout_width="72dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="RWF 0"
        android:textSize="13sp"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginStart="8dp" />

</LinearLayout>