<?xml version="1.0" encoding="utf-8"?>
<!--
    item_pos_product.xml  ✅ Same IDs · ✅ Button default text uses @string/
    All other text values are set by POSProductAdapter at runtime.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_bg"
    android:padding="12dp"
    android:layout_margin="4dp"
    android:gravity="center"
    android:elevation="2dp">

    <!-- Emoji -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp">

        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/onboarding_inner_circle" />

        <TextView
            android:id="@+id/tvPosEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="📦"
            android:textSize="30sp" />

    </FrameLayout>

    <!-- Name — set by adapter -->
    <TextView
        android:id="@+id/tvPosProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/ink_dark"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="8dp" />

    <!-- Price — set by adapter -->
    <TextView
        android:id="@+id/tvPosPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginTop="4dp" />

    <!-- Stock — set by adapter -->
    <TextView
        android:id="@+id/tvPosStock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/ink_soft"
        android:layout_marginTop="2dp" />

    <!-- Add to cart button — default text localised -->
    <TextView
        android:id="@+id/btnAddToCart"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:gravity="center"
        android:text="@string/pos_add_btn"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/btn_primary"
        android:layout_marginTop="8dp" />

</LinearLayout>