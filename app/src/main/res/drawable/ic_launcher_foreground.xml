<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher_foreground.xml
    SwiftSales — Adaptive Icon Foreground
    Safe zone: 72×72dp centered in 108×108dp canvas
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer glow ring (subtle) -->
    <path
        android:fillColor="#1AFFFFFF"
        android:pathData="M54,20 m-28,0 a28,28 0 1,0 56,0 a28,28 0 1,0 -56,0" />

    <!-- White circle background for icon -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,22 m-24,0 a24,24 0 1,0 48,0 a24,24 0 1,0 -48,0" />

    <!-- Bold lightning bolt — primary blue -->
    <path
        android:fillColor="#0EA5E9"
        android:pathData="M59,12 L38,50 L50,50 L49,68 L70,30 L58,30 Z" />

    <!-- Dollar / speed accent line — orange -->
    <path
        android:fillColor="#F97316"
        android:strokeColor="#F97316"
        android:strokeWidth="2.5"
        android:pathData="M44,72 L64,72"
        android:strokeLineCap="round" />

    <!-- Second accent line — shorter, lighter -->
    <path
        android:fillColor="#F97316"
        android:strokeColor="#F97316"
        android:strokeWidth="2"
        android:strokeAlpha="0.6"
        android:pathData="M48,78 L60,78"
        android:strokeLineCap="round" />

    <!-- "S" letterform hint — bottom right badge -->
    <path
        android:fillColor="#0EA5E9"
        android:pathData="M68,60 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0" />

    <path
        android:fillColor="#FFFFFF"
        android:pathData="M64.5,56.5 Q61,56 61,59 Q61,61.5 64.5,61.5 Q68,61.5 68,64 Q68,67 64.5,67" />

</vector>