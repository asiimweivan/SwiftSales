<resources>
    <style name="Theme.SwiftSales" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_deep</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/navy_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:fontFamily">@font/dm_sans_regular</item>
    </style>

    <!-- Splash Screen Theme (fullscreen, no status bar) -->
    <style name="Theme.SwiftSales.Splash" parent="Theme.SwiftSales">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@color/navy_dark</item>
        <item name="android:navigationBarColor">@color/navy_dark</item>
    </style>
</resources>